{
  "expo": {
    "name": "SoundPulse",
    "slug": "SoundPulse",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/soundpulse-icon-2048.png",
    "userInterfaceStyle": "dark",
    "scheme": "soundpulse",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/soundpulse-icon-2048.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A1A"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": ["audio"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/soundpulse-adaptive-foreground.png",
        "backgroundColor": "#0A0A1A"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-secure-store"
    ]
  }
}
